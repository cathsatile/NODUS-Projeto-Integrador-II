<?xml version="1.0" encoding="utf-8"?>
<!--
  Permite tráfego HTTP (sem TLS) para o backend local durante desenvolvimento.
  Cobre localhost e toda a faixa 192.168.x.x (rede Wi-Fi doméstica/escolar).
  Em produção, troque o backend por HTTPS e remova este arquivo.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">192.168.0.137</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
